            min-height: 5px;
        }

        .chart-bar:hover {
            background-color: var(--accent-hover);
        }

        .chart-tooltip {
            position: absolute;
            top: -25px;
            left: 50%;
            transform: translateX(-50%);
            background-color: var(--text-primary);
            color: var(--bg-primary);
            padding: 2px 6px;
            font-size: 0.75rem;
            font-weight: bold;
            border-radius: 4px;
            opacity: 0;
            transition: opacity 0.2s;
            pointer-events: none;
            white-space: nowrap;
        }

        .chart-bar:hover .chart-tooltip {
            opacity: 1;
        }

        .chart-label {
